{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.zovark.io/proof_package/edr-handoff/v1.0.0/schema.json",
  "title": "Proof Package — EDR Handoff (action card)",
  "description": "Approval-required EDR action card. Nothing is dispatched (execution_result.status == pending). SHAPE contract only; linkage to the verified tape is enforced by proof-package-verify.",
  "x-zovark-schema-version": "1.0.0",
  "x-zovark-owner": "zovark-runtime",
  "x-zovark-visibility": "internal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_type", "approval_mode", "audit_ref", "authorization_record_ref", "blast_radius",
    "evidence_refs", "execution_result", "handoff_id", "idempotency_key", "policy_snapshot",
    "policy_snapshot_version", "replay_linkage", "rollback_plan", "tape_ref", "target", "tenant_id"
  ],
  "properties": {
    "action_type": { "type": "string", "enum": ["isolate_host", "notify_only"] },
    "approval_mode": { "const": "approval_required" },
    "audit_ref": { "type": "string", "pattern": "^audit-entry-[0-9]+$" },
    "authorization_record_ref": { "const": "vault://placeholder/bootstrap" },
    "blast_radius": {
      "type": "object",
      "additionalProperties": false,
      "required": ["directly_affected", "estimated_business_impact", "lateral_movement_blocked", "services_at_risk"],
      "properties": {
        "directly_affected": { "type": "array", "items": { "type": "string" } },
        "estimated_business_impact": { "type": "string" },
        "lateral_movement_blocked": { "type": "array", "items": { "type": "string" } },
        "services_at_risk": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^ev-[0-9a-f]{64}$" }
    },
    "execution_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["completed_at", "error", "reason", "started_at", "status", "vendor_response_ref"],
      "properties": {
        "completed_at": { "const": null },
        "error": { "const": null },
        "reason": { "type": "string", "minLength": 1 },
        "started_at": { "const": null },
        "status": { "const": "pending" },
        "vendor_response_ref": { "const": null }
      }
    },
    "handoff_id": { "type": "string", "pattern": "^handoff-[0-9a-f]{16}$" },
    "idempotency_key": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "policy_snapshot": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "policy_snapshot_version": { "type": "string", "minLength": 1 },
    "replay_linkage": { "type": "array" },
    "rollback_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idempotency_key", "manual_steps", "recovery_notes", "reversibility_class", "reversal_window", "vendor_reversal_action", "vendor_reversal_target"],
      "properties": {
        "idempotency_key": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "manual_steps": { "type": "array" },
        "recovery_notes": { "type": "string", "minLength": 1 },
        "reversibility_class": { "type": "string", "enum": ["automatic", "manual_documented", "irreversible"] },
        "reversal_window": { "type": "string", "minLength": 1 },
        "vendor_reversal_action": { "type": "string", "minLength": 1 },
        "vendor_reversal_target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["identifier", "kind"],
          "properties": {
            "identifier": { "type": "string", "minLength": 1 },
            "kind": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "tape_ref": { "type": "string", "pattern": "^tape-[0-9a-f]{16}$" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identifier", "kind", "validated_at"],
      "properties": {
        "identifier": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["host", "custom"] },
        "validated_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
        "fqdn": { "type": "string", "minLength": 1 }
      }
    },
    "tenant_id": { "type": "string", "minLength": 1 }
  }
}
